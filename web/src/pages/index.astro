---
import Base from '../layouts/Base.astro';
import Studio from '../components/Studio';
import Subtitle from '../components/Subtitle';
import LangToggle from '../components/LangToggle';
import Footer from '../components/Footer';
import PwaInstallPrompt from '../components/PwaInstallPrompt';
---
<Base title="orber">
  <LangToggle client:only="solid-js" />
  <h1 class="font-display text-5xl font-light tracking-logo lowercase text-fg text-center pl-[0.4em]">orber</h1>
  <Subtitle client:only="solid-js" />
  <Studio client:only="solid-js" />
  {/* #128: Footer は Studio の自然なスクロール末尾に着地。client:visible で
      初期描画コストを下げる (画面に入った時点でだけ hydrate)。 */}
  <Footer client:only="solid-js" />
  {/* #148: PWA install prompt は beforeinstallprompt を捕まえる必要があるので
      client:load で早めに hydrate する。普段は不可視で、browser がインストール
      可能と判定したときだけ画面下のトーストとして visible になる。 */}
  <PwaInstallPrompt client:only="solid-js" />
</Base>
